{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "distDir": "client/dist"
      }
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/_/backend/(.*)", "destination": "/backend/index.js" },
    { "source": "/api/(.*)", "destination": "/backend/index.js" },
    { "source": "/health", "destination": "/backend/index.js" },
    { "source": "/((?!api/|health|_/backend).*).*", "destination": "/$1" }
  ]
}
